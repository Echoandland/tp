<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="false" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <HBox fx:id="helpMessageContainer" alignment="CENTER_LEFT" spacing="4">
        <padding>
          <Insets top="16" right="20" bottom="16" left="20" />
        </padding>
        <Label fx:id="helpMessage" text="Please refer to the user guide: " />
        <Hyperlink fx:id="userGuideLink" onAction="#openUrl" />
        <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy">
          <HBox.margin>
            <Insets left="6" />
          </HBox.margin>
        </Button>
      </HBox>
    </Scene>
  </scene>
</fx:root>
