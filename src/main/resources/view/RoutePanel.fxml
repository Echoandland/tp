<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="route-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

  <Label text="ROUTE PLANNER" styleClass="section-title" />

  <Button fx:id="planRoutesButton"
          text="Plan Today's Routes"
          onAction="#handlePlanRoutes"
          styleClass="plan-routes-button"
          visible="false"
          managed="false">
    <VBox.margin>
      <Insets top="8" bottom="4" />
    </VBox.margin>
  </Button>

  <Label fx:id="routeStatusLabel" text="" styleClass="route-status">
    <VBox.margin>
      <Insets top="4" bottom="10" />
    </VBox.margin>
  </Label>

  <!-- Map fills remaining vertical space -->
  <StackPane fx:id="mapPlaceholder" styleClass="map-container" VBox.vgrow="ALWAYS" />

</VBox>
