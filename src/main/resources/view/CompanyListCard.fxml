<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER_LEFT" spacing="0">
  <padding>
    <Insets top="10" right="14" bottom="10" left="14" />
  </padding>

  <VBox HBox.hgrow="ALWAYS" spacing="4">

    <!-- Row 1: index · name (primary) + tags -->
    <HBox spacing="6" alignment="CENTER_LEFT">
      <Label fx:id="id" styleClass="card-index" />
      <Label fx:id="name" text="\$first" styleClass="card-name" />
      <Region HBox.hgrow="ALWAYS" />
      <FlowPane fx:id="tags" alignment="CENTER_RIGHT" hgap="4" vgap="3" />
    </HBox>

    <!-- Row 2: metadata (phone · email · address) -->
    <HBox spacing="14" alignment="CENTER_LEFT">
      <Label fx:id="phone" styleClass="card-meta" text="\$phone" />
      <Label fx:id="email" styleClass="card-meta" text="\$email" />
      <Label fx:id="address" styleClass="card-meta" text="\$address" />
    </HBox>

  </VBox>
</HBox>
