<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER_LEFT" spacing="10">
  <padding>
    <Insets top="10" right="14" bottom="10" left="14" />
  </padding>

  <CheckBox fx:id="selectDeliveryCheckBox" />

  <VBox HBox.hgrow="ALWAYS" spacing="4">

    <!-- Row 1: index · product (primary) + deadline badge + tags -->
    <HBox spacing="6" alignment="CENTER_LEFT">
      <Label fx:id="id" styleClass="card-index" />
      <Label fx:id="product" text="$product" styleClass="card-name" />
      <Region HBox.hgrow="ALWAYS" />
      <Label fx:id="deadline" styleClass="deadline-badge" text="$deadline" />
      <FlowPane fx:id="tags" alignment="CENTER_RIGHT" hgap="4" vgap="3" />
    </HBox>

    <!-- Row 2: company · address -->
    <HBox spacing="14" alignment="CENTER_LEFT">
      <Label fx:id="company" styleClass="card-meta" text="$company" />
      <Label fx:id="address" styleClass="card-meta" text="$address" />
    </HBox>

  </VBox>
</HBox>
